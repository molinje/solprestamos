<mvc:View
  controllerName="prestamos.ccb.org.solprestamos.controller.View3"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  displayBlock="true"
  xmlns="sap.m">
  <Page
    id="page3"
    title="Préstamo educativo"
    showNavButton="true"
    navButtonPress=".onNavBack">
    <content>
        <Wizard id="wizardEduca" complete="onWizardComplete" class="sapUiResponsiveMargin">
                
                <!-- Paso 1: Datos del Préstamo Educativo -->
                <WizardStep
                    id="step01"
                    title="Datos del Préstamo"
                    validated="true">
                    <!-- Grid responsivo: 2 columnas en L/M, 1 columna en S -->
                    <layout:Grid defaultSpan="L6 M6 S12" class="sapUiSmallMargin">

                        <!-- Fila 1: Tipo de Educación | Nivel -->
                        <VBox>
                            <Label text="Tipo de Educación"/>
                            <Select id="selectTipoEducacion" selectedKey="{educaView>/tipoEducacion}" forceSelection="false" width="100%" change="onTipoEducacionChange">
                                <core:Item key="2" text="Pregrado"/>
                                <core:Item key="1" text="Postgrado"/>
                            </Select>
                        </VBox>
                        <VBox>
                            <Label text="Nivel"/>
                            <Select id="selectNivel" selectedKey="{educaView>/Nivel}" forceSelection="false" width="100%">
                                <core:Item key="01" text="1"/>
                                <core:Item key="02" text="2"/>
                                <core:Item key="03" text="3"/>
                                <core:Item key="04" text="4"/>
                                <core:Item key="05" text="5"/>
                                <core:Item key="06" text="6"/>
                                <core:Item key="07" text="7"/>
                                <core:Item key="08" text="8"/>
                                <core:Item key="09" text="9"/>
                                <core:Item key="10" text="10"/>
                                <core:Item key="11" text="11"/>
                                <core:Item key="12" text="12"/>
                            </Select>
                        </VBox>

                        <!-- Fila 2: Periodicidad | N. Cuotas -->
                        <VBox>
                            <Label text="Periodicidad"/>
                            <Select id="selectPeriodicidad" selectedKey="{educaView>/Periodicidad}" forceSelection="false" width="100%">
                                <core:Item key="1" text="Anual"/>
                                <core:Item key="4" text="Cuatrimestral"/>
                                <core:Item key="2" text="Semestral"/>
                            </Select>
                        </VBox>
                        <VBox>
                            <Label text="N. Cuotas"/>
                            <Select
                                id="selectCuotasEduca"
                                selectedKey="{educaView>/NCuotas}"
                                forceSelection="false"
                                width="100%"
                                change="onCuotasChange"
                                valueState="{educaView>/cuotasValueState}"
                                valueStateText="{educaView>/cuotasValueStateText}"
                                items="{educaView>/CuotasEducaCollection}">
                                <core:Item key="{educaView>CuotasId}" text="{educaView>Name}"/>
                            </Select>
                        </VBox>

                        <!-- Fila 3: Valor Solicitado | Valor Préstamo -->
                        <VBox>
                            <Label text="Valor Solicitado" labelFor="inputValorSolicitado"/>
                            <Input
                                id="inputValorSolicitado"
                                value="{educaView>/valorSolicitado}"
                                type="Number"
                                width="100%"
                                placeholder="Ingrese el valor solicitado"
                                change="onValorSolicitadoChange"
                                valueState="{educaView>/valorValueState}"
                                valueStateText="{educaView>/valorValueStateText}"/>
                        </VBox>
                        <VBox>
                            <Label text="Valor Préstamo" labelFor="inputValorPrestamo"/>
                            <Input
                                id="inputValorPrestamo"
                                value="{educaView>/valorPrestamo}"
                                type="Number"
                                width="100%"
                                editable="false"/>
                        </VBox>

                        <!-- Fila 4: Valor a pagar | Valor condonado -->
                        <VBox>
                            <Label text="Valor a pagar" labelFor="inputValorValorPagar"/>
                            <Input
                                id="inputValorValorPagar"
                                value="{educaView>/ValorPagar}"
                                type="Number"
                                width="100%"
                                editable="false"/>
                        </VBox>
                        <VBox>
                            <Label text="Valor condonado" labelFor="inputValorCondonado"/>
                            <Input
                                id="inputValorCondonado"
                                value="{educaView>/valorCondonado}"
                                type="Number"
                                width="100%"
                                editable="false"/>
                        </VBox>

                        <!-- Fila 5: Valor cuota (columna izquierda) -->
                        <VBox>
                            <Label text="Valor cuota" labelFor="inputValorValorCuota"/>
                            <Input
                                id="inputValorValorCuota"
                                value="{educaView>/ValorCuota}"
                                type="Number"
                                width="100%"
                                editable="false"/>
                        </VBox>
                        <VBox/>

                        <!-- Buscador de programa: ancho completo siempre -->
                        <VBox>
                            <layoutData>
                                <layout:GridData span="L12 M12 S12"/>
                            </layoutData>
                            <Label text="Buscar Programa / Universidad" labelFor="selectProgPregado"/>
                            <Input
                                id="selectProgPregado"
                                width="100%"
                                placeholder="Digite título, carrera o universidad para buscar..."
                                showSuggestion="true"
                                suggest="onSuggestPrograma"
                                suggestionItemSelected="onProgramaSeleccionado"
                                value="{educaView>/programaBusqueda}"/>
                        </VBox>

                        <VBox>
                            <layoutData>
                                <layout:GridData span="L12 M12 S12"/>
                            </layoutData>
                            <Label text="Buscar Programa / Universidad" labelFor="selectPostPregado"/>
                            <Input
                                id="selectPostPregado"
                                width="100%"
                                placeholder="Digite título, carrera o universidad para buscar..."
                                showSuggestion="true"
                                suggest="onSuggestPostgrado"
                                suggestionItemSelected="onPostgradoSeleccionado"
                                value="{educaView>/programaPostGradoBusqueda}"/>
                        </VBox>

                        <!-- Fila 6: Título del Programa | Universidad -->
                        <VBox>
                            <Label text="Título del Programa"/>
                            <Input
                                id="inputProgTitulo"
                                value="{educaView>/programaTitulo}"
                                width="100%"
                                editable="false"/>
                        </VBox>
                        <VBox>
                            <Label text="Universidad"/>
                            <Input
                                id="inputProgUniversidad"
                                value="{educaView>/programaUniversidad}"
                                width="100%"
                                editable="false"/>
                        </VBox>

                        <!-- Fila 7: Carrera / Programa | Origen Universidad -->
                        <VBox>
                            <Label text="Carrera / Programa"/>
                            <Input
                                id="inputProgCarrera"
                                value="{educaView>/programaCarrera}"
                                width="100%"
                                editable="false"/>
                        </VBox>
                        <VBox>
                            <Label text="Origen Universidad"/>
                            <Select selectedKey="{educaView>/OrigenU}" forceSelection="false" width="100%">
                                <core:Item key="01" text="Colombia"/>
                                <core:Item key="02" text="Ecuador"/>
                                <core:Item key="03" text="Perú"/>
                                <core:Item key="04" text="Brasil"/>
                                <core:Item key="05" text="España"/>
                                <core:Item key="06" text="EE.UU."/>
                            </Select>
                        </VBox>


                    </layout:Grid>
                </WizardStep>
                
                <WizardStep
                    id="step012"
                    title="Primas y bonificaciones"
                    validated="true">
                    <!-- Grid responsivo: 2 columnas en L/M, 1 columna en S -->
                    <layout:Grid defaultSpan="L6 M6 S12" class="sapUiSmallMargin">

                        <!-- Fila: Descuento en Primas | Porcentaje -->
                        <VBox>
                            <Label text="Primas y Bonificaciones"/>
                            <Select
                                selectedKey="{educaView>/SelectedPrimas}"
                                forceSelection="false"
                                width="100%"
                                change=".onChangePrimas3">
                               <items>
                                        <core:Item key="NO_APLICA" text="No Aplica"/>
                                        <core:Item key="DESCONTAR_PRIMAS" text="Descontar Primas"/>
                              </items>
                            </Select>
                        </VBox>
                        <VBox>
                            <Label text="Porcentaje %"/>
                            <Select selectedKey="{educaView>/PorcentajePrima}" forceSelection="false" width="100%">
                                <core:Item key="10" text="10%"/>
                                <core:Item key="20" text="20%"/>
                                <core:Item key="30" text="30%"/>
                                <core:Item key="40" text="40%"/>
                                <core:Item key="50" text="50%"/>
                                <core:Item key="60" text="60%"/>
                            </Select>
                        </VBox>

                    </layout:Grid>

                    <Table
                        id="tablaPrimas3"
                        items="{listprimas3>/items}"
                        visible="{= ${educaView>/SelectedPrimas} === 'DESCONTAR_PRIMAS' }"
                        class="sapUiSmallMargin">
                        <headerToolbar>
                            <Toolbar>
                                <Title text="Primas a Descontar"/>
                                <ToolbarSpacer/>
                                <Button
                                    icon="sap-icon://add"
                                    press=".onAddPrimas3"
                                    tooltip="Agregar prima"/>
                                <Button
                                    icon="sap-icon://less"
                                    press=".onReducePrimas3"
                                    tooltip="Eliminar última prima"/>
                            </Toolbar>
                        </headerToolbar>
                        <columns>
                            <Column>
                                <Text text="Fecha Inicio"/>
                            </Column>
                            <Column>
                                <Text text="Valor Comprometido"/>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{listprimas3>FECHA_PRIMA}"/>
                                    <ObjectNumber
                                        number="{
                                            parts: [
                                                {path: 'listprimas3>VALOR_PRIMA'},
                                                {path: 'listprimas3>MONEDA_PRIMA'}
                                            ],
                                            type: 'sap.ui.model.type.Currency',
                                            formatOptions: { showMeasure: true }
                                        }"
                                        />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                </WizardStep>
               
                <!-- Paso 2: Datos del codeudor -->
                <WizardStep
                    id="step02"
                    title="Datos codeudor"
                    validated="false"
                    activate="onStepCodeudorActivate3">
                    <VBox class="sapUiSmallMargin">
                        <form:SimpleForm editable="true" layout="ResponsiveGridLayout">

                            <Label text="¿Codeudor es trabajador de la CCB?" class="sapUiSmallMarginBottom"/>
                            <RadioButtonGroup
                                id="rbGroupCodeudor3"
                                selectedIndex="{educaView>/tieneCodeudor}"
                                select="onCodeudorTypeSelect3">
                                <RadioButton text="Sí"/>
                                <RadioButton text="No"/>
                            </RadioButtonGroup>

                            <!-- Codeudor CCB (empleado interno) -->
                            <Label text="Búsqueda colaborador" labelFor="inputIdentificacion3" visible="{educaView>/mostrarCCB}"/>
                            <Input
                                id="inputIdentificacion3"
                                showValueHelp="true"
                                valueHelpRequest="onIdentificacionValueHelp3"
                                placeholder="Busque por nombre o identificación"
                                visible="{educaView>/mostrarCCB}"/>

                            <Label text="Nombre" labelFor="CodeudorNombre3" visible="{educaView>/mostrarCCB}"/>
                            <Input
                                id="CodeudorNombre3"
                                value="{educaView>/nombreCodeudor}"
                                editable="false"
                                width="100%"
                                visible="{educaView>/mostrarCCB}"/>

                            <Label text="Núm. de empleado" labelFor="CodeudorNumEmpleado3" visible="{educaView>/mostrarCCB}"/>
                            <Input
                                id="CodeudorNumEmpleado3"
                                value="{educaView>/numeroEmpleadoCodeudor}"
                                editable="false"
                                width="100%"
                                visible="{educaView>/mostrarCCB}"/>

                            <Label text="Cédula" labelFor="CodeudorCedula3" visible="{educaView>/mostrarCCB}"/>
                            <Input
                                id="CodeudorCedula3"
                                value="{educaView>/cedulaCodeudor}"
                                editable="false"
                                width="100%"
                                visible="{educaView>/mostrarCCB}"/>

                            <!-- Codeudor externo -->
                            <Label text="Nombre" labelFor="CodeudorNombreEx3" visible="{educaView>/mostrarExterno}"/>
                            <Input
                                id="CodeudorNombreEx3"
                                value="{educaView>/nombreCodeudor}"
                                editable="true"
                                width="100%"
                                visible="{educaView>/mostrarExterno}"
                                change="onStepCodeudorActivate3"/>

                            <Label text="Cédula" labelFor="CodeudorCedulaEx3" visible="{educaView>/mostrarExterno}"/>
                            <Input
                                id="CodeudorCedulaEx3"
                                value="{educaView>/cedulaCodeudor}"
                                editable="true"
                                width="100%"
                                visible="{educaView>/mostrarExterno}"
                                change="onStepCodeudorActivate3"/>

                            <Label text="Dirección" labelFor="CodeudorDireccionEx3" visible="{educaView>/mostrarExterno}"/>
                            <Input
                                id="CodeudorDireccionEx3"
                                value="{educaView>/direccionCodeudor}"
                                editable="true"
                                width="100%"
                                visible="{educaView>/mostrarExterno}"
                                change="onStepCodeudorActivate3"/>

                            <Label text="Teléfono" labelFor="CodeudorTelefonoEx3" visible="{educaView>/mostrarExterno}"/>
                            <Input
                                id="CodeudorTelefonoEx3"
                                value="{educaView>/telefonoCodeudor}"
                                editable="true"
                                width="100%"
                                visible="{educaView>/mostrarExterno}"
                                change="onStepCodeudorActivate3"/>

                        </form:SimpleForm>
                    </VBox>
                </WizardStep>
                

                
                <!-- Paso 4: Documentos -->
                <WizardStep
                    id="step03"
                    title="Soportes"
                    validated="true">
                    <VBox class="sapUiSmallMargin">
                        <Toolbar>
                            <Title text="Documentos Adjuntos"/>
                            <ToolbarSpacer/>
                            <Button
                                text="Agregar"
                                icon="sap-icon://add"
                                type="Emphasized"
                                press="onAgregarDocumento3"/>
                        </Toolbar>

                        <Table
                            id="tableAdjuntos3"
                            items="{educaView>/adjuntos}"
                            noDataText="No hay documentos adjuntos. Use el botón Agregar."
                            class="sapUiSmallMarginBottom">
                            <columns>
                                <Column width="60%">
                                    <Text text="Nombre de Archivo"/>
                                </Column>
                                <Column width="40%">
                                    <Text text="Tipo de Documento"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{educaView>nombreArchivo}"/>
                                        <Text text="{educaView>tipoArchivoText}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <Button
                            id="btnCrearSolicitud3"
                            text="Crear Solicitud"
                            type="Emphasized"
                            press="onCrearSolicitud"
                            enabled="{educaView>/solicitudEnabled}"
                            class="sapUiMediumMarginTop"
                            width="200px"/>
                    </VBox>
                </WizardStep>
                
       </Wizard>
      <VBox
        alignItems="Center"
        justifyContent="Center"
        class="sapUiMediumMarginTop">
        <items>

          <Button
            text="Volver al Inicio"
            type="Emphasized"
            icon="sap-icon://home"
            press=".onNavBack"
            class="sapUiSmallMarginTop"/>
        </items>
      </VBox>
    </content>
  </Page>
</mvc:View>