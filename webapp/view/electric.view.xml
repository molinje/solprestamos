<mvc:View
  controllerName="prestamos.ccb.org.solprestamos.controller.electric"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  displayBlock="true"
  xmlns="sap.m">
  <Page
    id="Pageelectric"
    title="Préstamo Movilidad Eléctrica"
    showNavButton="true"
    navButtonPress=".onNavBack">
    <content>
        <Wizard id="wizardelectric" complete="onWizardComplete" class="sapUiResponsiveMargin">

                <!-- Paso 1: Datos del Préstamo -->
                <WizardStep
                    id="stepelectric01"
                    title="Datos del Préstamo"
                    validated="false"
                    activate="onStep1Activate">
                   <VBox class="sapUiSmallMargin">
                        <form:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout">

                        <Label text="Valor Solicitado *" labelFor="inputValorSolicMelectric" class="sapUiSmallMarginBottom" required="true"/>
                        <Input
                            id="inputValorSolicMelectric"
                            value="{
                                parts: [
                                    {path: 'movelectricView>/valorSolicitado'},
                                    {path: 'movelectricView>/moneda'}
                                ],
                                type: 'sap.ui.model.type.Currency',
                                formatOptions: {
                                    showMeasure: true,
                                    currencyCode: true,
                                    maxFractionDigits: 0
                                }
                            }"
                            change="onValorSolicitadoChange"
                            width="100%"
                            textAlign="End"
                            valueState="{movelectricView>/valorValueState}"
                            valueStateText="{movelectricView>/valorValueStateText}"
                            placeholder="Ingrese el valor solicitado"/>

                        <Label text="N Cuotas *" labelFor="selectCuotasMelectric" class="sapUiSmallMarginBottom" required="true"/>
                        <Select
                            id="selectCuotasMelectric"
                            selectedKey="{movelectricView>/selectedCuotas}"
                            width="100%"
                            change="onCuotasChange"
                            valueState="{movelectricView>/cuotasValueState}"
                            valueStateText="{movelectricView>/cuotasValueStateText}"
                            items="{movelectricView>/CuotasCollection}">
                            <core:Item key="{movelectricView>CuotasId}" text="{movelectricView>Name}"/>
                        </Select>

                        <Label text="Valor préstamo" labelFor="ValorPrestamoMelectric" class="sapUiSmallMarginTop"/>
                        <Input
                            id="ValorPrestamoMelectric"
                            value="{
                                parts: [
                                    {path: 'movelectricView>/ValorPrestamoMelectric'},
                                    {path: 'movelectricView>/moneda'}
                                ],
                                type: 'sap.ui.model.type.Currency',
                                formatOptions: {
                                    showMeasure: true,
                                    currencyCode: true,
                                    maxFractionDigits: 0
                                }
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End"/>

                        <Label text="Valor cuota préstamo" labelFor="ValorCuotaMelectric" class="sapUiSmallMarginTop"/>
                        <Input
                            id="ValorCuotaMelectric"
                            value="{
                                parts: [
                                    {path: 'movelectricView>/ValorCuotaMelectric'},
                                    {path: 'movelectricView>/moneda'}
                                ],
                                type: 'sap.ui.model.type.Currency',
                                formatOptions: {
                                    showMeasure: true,
                                    currencyCode: true,
                                    maxFractionDigits: 0
                                }
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End"/>

                        <Label text="Destino" labelFor="selectDestinoMelectric"/>
                        <Select selectedKey="{/Destino}" width="100%" id="selectDestinoMelectric">
                            <core:Item key="01" text="Colaborador"/>
                            <core:Item key="02" text="Proveedor"/>
                        </Select>

                        <Label text="Descuento en Primas" labelFor="selectDescuentoPrimasMelectric"/>
                        <Select selectedKey="{movelectricView>/descuentoPrimas}" width="100%" id="selectDescuentoPrimasMelectric">
                            <core:Item key="NO" text="No Aplica"/>
                            <core:Item key="SI" text="Descontar Primas"/>
                        </Select>

                        </form:SimpleForm>

                        <Table
                            id="tablaPrimasElectric"
                            items="{listprimasElectric>/items}"
                            visible="{= ${movelectricView>/descuentoPrimas} === 'SI' }"
                            headerToolbar="true">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="Primas a Descontar"/>
                                    <ToolbarSpacer/>
                                    <Button
                                        icon="sap-icon://add"
                                        press=".onAddPrimas"
                                        tooltip="Agregar prima"/>
                                    <Button
                                        icon="sap-icon://less"
                                        press=".onReducePrimas"
                                        tooltip="Eliminar última prima"/>
                                </Toolbar>
                            </headerToolbar>
                            <columns>
                                <Column>
                                    <Text text="Fecha Inicio"/>
                                </Column>
                                <Column>
                                    <Text text="Valor Prima"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{listprimasElectric>FECHA_PRIMA}"/>
                                        <ObjectNumber
                                            number="{
                                                parts: [
                                                    {path: 'listprimasElectric>VALOR_PRIMA'},
                                                    {path: 'listprimasElectric>MONEDA_PRIMA'}
                                                ],
                                                type: 'sap.ui.model.type.Currency',
                                                formatOptions: { showMeasure: true }
                                            }"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- Botón de Siguiente -->
                        <Button
                            text="Siguiente"
                            type="Emphasized"
                            icon="sap-icon://navigation-right-arrow"
                            iconFirst="false"
                            press="onValidateStep1"
                            class="sapUiSmallMarginTop"/>
                    </VBox>
                </WizardStep>

                <!-- Paso 2: Primas y Bonificaciones -->
                <WizardStep
                    id="stepMElectric02"
                    title="Primas y Bonificaciones"
                    validated="true">
                    <VBox class="sapUiSmallMargin">
                        <form:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout">
                        <Label text="Descuento en Primas" labelFor="ValorDescPrimasMelectric"/>
                        <Input
                            id="ValorDescPrimasMelectric"
                            value="{
                                parts: [
                                    {path: 'movelectricView>/ValorDescPrimasMelectric'},
                                    {path: 'movelectricView>/moneda'}
                                ],
                                type: 'sap.ui.model.type.Currency',
                                formatOptions: {
                                    showMeasure: true,
                                    currencyCode: true,
                                    maxFractionDigits: 0
                                }
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End"/>
                        </form:SimpleForm>
                    </VBox>
                </WizardStep>

                <!-- Paso 3: Soportes -->
                <WizardStep
                    id="stepMElectric03"
                    title="Soportes"
                    validated="true">
                    <VBox class="sapUiSmallMargin">
                        <Label text="Adjuntar Documentos" class="sapUiSmallMarginBottom"/>
                        <UploadCollection
                            id="uploadCollectionMelectric"
                            uploadUrl="/upload"
                            multiple="true"
                            uploadComplete="onUploadComplete">
                        </UploadCollection>

                        <Button
                            id="btnCrearSolicPMelectric"
                            text="Crear Solicitud"
                            type="Emphasized"
                            press="onCrearSolicitud"
                            enabled="{movelectricView>/solicitudEnabled}"
                            class="sapUiMediumMarginTop"
                            width="200px"/>
                    </VBox>
                </WizardStep>

       </Wizard>
      <VBox
        alignItems="Center"
        justifyContent="Center"
        class="sapUiMediumMarginTop">
        <items>
          <Button
            text="Volver al Inicio"
            type="Emphasized"
            icon="sap-icon://home"
            press=".onNavBack"
            class="sapUiSmallMarginTop"/>
        </items>
      </VBox>
    </content>
  </Page>
</mvc:View>
