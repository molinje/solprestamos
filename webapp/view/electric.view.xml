<mvc:View
  controllerName="prestamos.ccb.org.solprestamos.controller.electric"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  displayBlock="true"
  xmlns="sap.m">
  <Page
    id="Pageelectric"
    title="Préstamo Movilidad Eléctrica"
    showNavButton="true"
    navButtonPress=".onNavBack">
    <content>
        <Wizard id="wizardelectric" 
                complete="onCrearSolicitud" 
                finishButtonText="Enviar Solicitud" 
                class="sapUiResponsiveMargin">

                <!-- Paso 1: Datos del Préstamo -->
                <WizardStep
                    id="stepelectric01"
                    title="Datos del Préstamo"
                    validated="false"
                    activate="onStep1Activate">
                   <VBox class="sapUiSmallMargin">
                        <form:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout">

                        <Label text="Monto máximo a solicitar" labelFor="MaxValorMelectric" />
                        <Input
                            id="MaxValorMelectric"
                            value="{
                                parts: [
                                    {path: 'movelectricView>/montoMaximo'},
                                    {path: 'movelectricView>/moneda'}
                                ],
                                type: 'sap.ui.model.type.Currency',
                                formatOptions: {
                                    showMeasure: true,
                                    currencyCode: true,
                                    maxFractionDigits: 0
                                }
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End"
                            />

                        <Label text="Valor Solicitado *" labelFor="inputValorSolicMelectric" class="sapUiSmallMarginBottom" required="true"/>
                        <HBox width="100%" alignItems="Center">
                            <Input
                                id="inputValorSolicMelectric"
                                value="{
                                    parts: [
                                        {path: 'movelectricView>/valorSolicitado'},
                                        {path: 'movelectricView>/moneda'}
                                    ],
                                    type: 'sap.ui.model.type.Currency',
                                    formatOptions: {
                                        showMeasure: false,
                                        maxFractionDigits: 0
                                    }
                                }"
                                change="onValorSolicitadoChange"
                                width="100%"
                                textAlign="End"
                                valueState="{movelectricView>/valorValueState}"
                                valueStateText="{movelectricView>/valorValueStateText}"
                                placeholder="Ingrese el valor solicitado"/>
                            <Input
                                value="{movelectricView>/moneda}"
                                editable="false"
                                width="5rem"
                                textAlign="Center"
                                class="sapUiSmallMarginBegin"/>
                        </HBox>

                        <Label text="N Cuotas *" labelFor="selectCuotasMelectric" class="sapUiSmallMarginBottom" required="true"/>
                        <Select
                            id="selectCuotasMelectric"
                            selectedKey="{movelectricView>/selectedCuotas}"
                            width="100%"
                            change="onCuotasChange"
                            valueState="{movelectricView>/cuotasValueState}"
                            valueStateText="{movelectricView>/cuotasValueStateText}"
                            items="{movelectricView>/CuotasCollection}">
                            <core:Item key="{movelectricView>CuotasId}" text="{movelectricView>Name}"/>
                        </Select>

                        <Label text="Valor préstamo" labelFor="ValorPrestamoMelectric" class="sapUiSmallMarginTop"/>
                        <Input
                            id="ValorPrestamoMelectric"
                            value="{
                                parts: [
                                    {path: 'movelectricView>/ValorPrestamoMelectric'},
                                    {path: 'movelectricView>/moneda'}
                                ],
                                type: 'sap.ui.model.type.Currency',
                                formatOptions: {
                                    showMeasure: true,
                                    currencyCode: true,
                                    maxFractionDigits: 0
                                }
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End"/>

                        <Label text="Valor cuota préstamo" labelFor="ValorCuotaMelectric" class="sapUiSmallMarginTop"/>
                        <Input
                            id="ValorCuotaMelectric"
                            value="{
                                parts: [
                                    {path: 'movelectricView>/ValorCuotaMelectric'},
                                    {path: 'movelectricView>/moneda'}
                                ],
                                type: 'sap.ui.model.type.Currency',
                                formatOptions: {
                                    showMeasure: true,
                                    currencyCode: true,
                                    maxFractionDigits: 0
                                }
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End"/>

                        <Label text="Destino *" labelFor="selectDestinoMelectric" required="true"/>
                        <Select
                            id="selectDestinoMelectric"
                            forceSelection="false"
                            selectedKey="{movelectricView>/selectedDestino}"
                            change="onDestinoChange"
                            width="100%"
                            valueState="{movelectricView>/destinoValueState}"
                            valueStateText="{movelectricView>/destinoValueStateText}">
                            <core:Item key="" text="Seleccione una opción"/>
                            <core:Item key="01" text="Colaborador"/>
                            <core:Item key="02" text="Proveedor"/>
                        </Select>

                        <Label text="Descuento en Primas" labelFor="selectDescuentoPrimasMelectric"/>
                        <Select selectedKey="{movelectricView>/descuentoPrimas}" width="100%" id="selectDescuentoPrimasMelectric">
                            <core:Item key="NO" text="No Aplica"/>
                            <core:Item key="SI" text="Descontar Primas"/>
                        </Select>

                        </form:SimpleForm>

                        <Table
                            id="tablaPrimasElectric"
                            items="{listprimasElectric>/items}"
                            visible="{= ${movelectricView>/descuentoPrimas} === 'SI' }"
                            headerToolbar="true">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="Primas a Descontar"/>
                                    <ToolbarSpacer/>
                                    <Button
                                        icon="sap-icon://add"
                                        press=".onAddPrimas"
                                        tooltip="Agregar prima"/>
                                    <Button
                                        icon="sap-icon://less"
                                        press=".onReducePrimas"
                                        tooltip="Eliminar última prima"/>
                                </Toolbar>
                            </headerToolbar>
                            <columns>
                                <Column>
                                    <Text text="Fecha Inicio"/>
                                </Column>
                                <Column>
                                    <Text text="Valor Prima"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{listprimasElectric>FECHA_PRIMA}"/>
                                        <ObjectNumber
                                            number="{
                                                parts: [
                                                    {path: 'listprimasElectric>VALOR_PRIMA'},
                                                    {path: 'listprimasElectric>MONEDA_PRIMA'}
                                                ],
                                                type: 'sap.ui.model.type.Currency',
                                                formatOptions: { showMeasure: true }
                                            }"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- Botón de Siguiente -->
                        <Button
                            text="Siguiente"
                            type="Emphasized"
                            icon="sap-icon://navigation-right-arrow"
                            iconFirst="false"
                            press="onValidateStep1"
                            class="sapUiSmallMarginTop"/>
                    </VBox>
                </WizardStep>

                <!-- Paso 2: Documentos Adjuntos -->
                <WizardStep
                    id="stepMElectric03"
                    title="Soportes"
                    validated="true">
                    <VBox class="sapUiSmallMargin">
                        <Toolbar>
                            <Title text="Documentos Adjuntos"/>
                            <ToolbarSpacer/>
                            <Button
                                text="Agregar"
                                icon="sap-icon://add"
                                type="Emphasized"
                                press="onAgregarDocumento"/>
                        </Toolbar>

                        <Table
                            id="tableAdjuntosElectric"
                            items="{movelectricView>/adjuntos}"
                            noDataText="No hay documentos adjuntos. Use el botón Agregar."
                            class="sapUiSmallMarginBottom">
                            <columns>
                                <Column width="60%">
                                    <Text text="Nombre de Archivo"/>
                                </Column>
                                <Column width="40%">
                                    <Text text="Tipo de Documento"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{movelectricView>nombreArchivo}"/>
                                        <Text text="{movelectricView>tipoArchivoText}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </WizardStep>

       </Wizard>
      <VBox
        alignItems="Center"
        justifyContent="Center"
        class="sapUiMediumMarginTop">
        <items>
          <Button
            text="Volver al Inicio"
            type="Emphasized"
            icon="sap-icon://home"
            press=".onNavBack"
            class="sapUiSmallMarginTop"/>
        </items>
      </VBox>
    </content>
  </Page>
</mvc:View>
